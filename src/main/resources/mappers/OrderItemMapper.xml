<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.solvd.deliverycompany.dao.IOrderItemDAO">

    <resultMap id="OrderItemResultMap" type="com.solvd.deliverycompany.model.OrderItem">
        <id column="order_item_id" property="id"/>
        <result column="item_name" property="itemName"/>
        <result column="quantity" property="quantity"/>
        <result column="price" property="price"/>

    </resultMap>

    <select id="getAll"
            resultMap="OrderItemResultMap">

        SELECT order_item_id, item_name, quantity, price
        FROM order_items

    </select>

    <select id="getById"
            parameterType="long"
            resultMap="OrderItemResultMap">

        SELECT order_item_id, item_name, quantity, price
        FROM order_items
        WHERE order_item_id = #{id}

    </select>

    <insert id="insert"
            parameterType="com.solvd.deliverycompany.model.OrderItem"
            useGeneratedKeys="true"
            keyProperty="id">

        INSERT INTO order_items (
        item_name,
        quantity,
        price
        )
        VALUES (
        #{itemName},
        #{quantity},
        #{price}
        )

    </insert>

    <update id="update"
            parameterType="com.solvd.deliverycompany.model.OrderItem">

        UPDATE order_items
        SET
        item_name = #{itemName},
        quantity = #{quantity},
        price = #{price}
        WHERE order_item_id = #{id}

    </update>

    <delete id="delete"
            parameterType="long">

        DELETE FROM order_items
        WHERE order_item_id = #{id}

    </delete>

</mapper>